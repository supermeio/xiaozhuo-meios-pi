{
  "name": "xiaozhuo-meios-pi",
  "version": "0.1.0",
  "description": "meios — lightweight vertical agent powered by pi-mono engine",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "node --import tsx src/index.ts",
    "dev": "node --watch --import tsx src/index.ts",
    "build": "esbuild src/gateway.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/gateway.mjs --external:better-sqlite3 --external:chokidar --external:@mariozechner/pi-coding-agent --external:@mariozechner/pi-ai --external:@mariozechner/pi-agent-core --external:@aws-sdk/client-s3 --external:@daytonaio/sdk --external:@sinclair/typebox",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1008.0",
    "@daytonaio/sdk": "^0.149.0",
    "@mariozechner/pi-agent-core": "^0.57.1",
    "@mariozechner/pi-ai": "^0.57.1",
    "@mariozechner/pi-coding-agent": "^0.57.1",
    "@sinclair/typebox": "^0.34.0",
    "better-sqlite3": "^12.8.0",
    "chokidar": "^5.0.0",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "esbuild": "^0.27.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
